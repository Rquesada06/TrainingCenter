rules_version = '2';
// Source: https://firebase.google.com/docs/storage/security/core-syntax
//
// LauFit Firebase Storage Security Rules — Phase 4 (PROF-03)
//
// Trust boundary: client → Firebase Storage. These server-enforced rules are the
// ONLY authorization on uploaded photo bytes; the client SDK cannot enforce them.
//
// Key protection: T-04-03 (Tampering) — a user may read/write ONLY their own
// users/{uid}/* path (which holds users/{uid}/profile.jpg). The
// request.auth.uid == userId check denies any cross-user read or write.
//
// Content-type / size validation is intentionally out of scope for the MVP
// (T-04-05 accept): profile photos are display-only with no server-side
// execution. Revisit if user-supplied media risk grows.

service firebase.storage {
  match /b/{bucket}/o {
    // Users can read and write only their own profile directory.
    // This covers the profile.jpg path: users/{uid}/profile.jpg
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
